// =============================================================================
'STR#' ID_ADDON_MENU "Menu metinleri" {
/* [1] */   "Imar Hesap Paleti...            ^32500"
}

// =============================================================================
//  Palet (modeless) diyalogu
//  ONEMLI: Buradaki item sirasi (indeks) ResourceIds.hpp icindeki
//  PaletteControls enum'u ile BIREBIR aynidir (1..11 = etkilesimli kontroller,
//  12+ = statik etiketler).
// =============================================================================
'GDLG' ID_PALETTE_DLG Palette | grow   0   0  620  456  "Imar Hesap" {
/* [ 1] Ada        */  TextEdit      10   30   90   20
/* [ 2] Parsel     */  TextEdit     110   30   90   20
/* [ 3] Arsa m2    */  RealEdit     210   30  110   20
/* [ 4] KAKS       */  RealEdit     330   30   80   20
/* [ 5] TAKS       */  RealEdit     420   30   70   20
/* [ 6] Hesapla    */  Button       500   28  110   24   LargePlain  "Hesapla / Yenile"
/* [ 7] TabloListe */  SingleSelList 10   72  180  340   PartialItems  16  NoPartialItems
/* [ 8] TabloIcerik*/  SingleSelList 200  72  410  340   PartialItems  16  NoPartialItems
/* [ 9] CSV        */  Button        10  420  130   24   LargePlain  "CSV Disa Aktar"
/* [10] Durum      */  LeftText     150  424  460   18   SmallPlain  ""
/* [11] Ayrac      */  Separator     10   62  600    2
/* [12] */             LeftText      10   12   90   16   SmallPlain  "Ada No"
/* [13] */             LeftText     110   12   90   16   SmallPlain  "Parsel No"
/* [14] */             LeftText     210   12  110   16   SmallPlain  "Arsa Alani (m2)"
/* [15] */             LeftText     330   12   80   16   SmallPlain  "KAKS (Emsal)"
/* [16] */             LeftText     420   12   70   16   SmallPlain  "TAKS"
}

'DLGH' ID_PALETTE_DLG DLG_ImarPalette {
 1   ""   TextEdit_Ada
 2   ""   TextEdit_Parsel
 3   ""   RealEdit_Arsa
 4   ""   RealEdit_KAKS
